---
import Layout from '../layouts/Layout.astro';
import { fetchGalleryPage } from '../lib/gallery-page';
import { getImageUrl, getSanityClient } from '../lib/sanity';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const galleryPage = await fetchGalleryPage(getSanityClient());

const featuredThemes = [
	{
		cardBorder: 'border-yellow-100',
		badgeBg: 'bg-yellow-100',
		badgeText: 'text-yellow-700',
		highlightText: 'text-primary',
		glowGradient: 'from-yellow-300 to-yellow-500',
		ringBorder: 'border-yellow-400',
		ringClasses: 'ring-yellow-200 ring-offset-yellow-100',
		bubbleGradient: 'from-yellow-300 to-yellow-500',
		bubbleIcon: 'trophy',
		dotClasses: 'bg-yellow-400 ring-yellow-200',
	},
	{
		cardBorder: 'border-pink-100',
		badgeBg: 'bg-pink-100',
		badgeText: 'text-pink-700',
		highlightText: 'text-pink-500',
		glowGradient: 'from-pink-300 to-fuchsia-500',
		ringBorder: 'border-pink-300',
		ringClasses: 'ring-pink-200 ring-offset-pink-100',
		bubbleGradient: 'from-pink-300 to-fuchsia-500',
		bubbleIcon: 'brush',
		dotClasses: 'bg-pink-400 ring-pink-200',
	},
	{
		cardBorder: 'border-blue-100',
		badgeBg: 'bg-blue-100',
		badgeText: 'text-blue-700',
		highlightText: 'text-blue-500',
		glowGradient: 'from-blue-300 to-cyan-500',
		ringBorder: 'border-blue-300',
		ringClasses: 'ring-blue-200 ring-offset-blue-100',
		bubbleGradient: 'from-blue-300 to-cyan-500',
		bubbleIcon: 'rocket_launch',
		dotClasses: 'bg-blue-400 ring-blue-200',
	},
];

const badgeIcons = ['school', 'palette', 'rocket_launch'];
const featuredFallbackImages = [
	'https://lh3.googleusercontent.com/aida-public/AB6AXuBP31zG3o8Zm5-v28Hg_L4VW20iVnupazff00LdLWGLdsBZ0rzIjLwuXl4EPU7XqvW_f4oLjuVy8FbaHUowAm5rmvKBojohWuTzDVshkDisZdPP9XyGhTpxehO-UIdL94vth2g1pdvUL79ZgbFITb8E_-65yqDCFKjAsfCoKeRrRLAfjKFGFRRNjkfhbEU3HIyCzTmUUDrGj8Xf58PcboSfPSMcarI3Ns8MDMaSFYCKxli9LyY6R284pyibsGCO52iO0h7UJ-kCzOg',
	'https://lh3.googleusercontent.com/aida-public/AB6AXuDWsqjZkFQD4CM_1MJWj6CrCMnD6T3_CI14CyZxli3WPeK8uwWWFy49CH9-yaJcdr-2JbiSE7ZVWeQPYfAd8JIYT3auWQT6-a2oM3ocOglCz2EYLKL8pvQPbKzM4yk2Qt-LrpyjubHS27Ob70p8jukY12KUsxEJMvob9RFrK3mVkYPhRD3WnsJvCqyDYDtzR691S8UIbiXO6yjkEYxtR_xsO4fZVoqX0pDUb3deU22M0fxrLNXI4T_RphLpCafI8Bg-kxOVcWrP9YQ',
	'https://lh3.googleusercontent.com/aida-public/AB6AXuDAjR6lKIQAg1cark0HtFD8B97zNJT_23G_1dJQ54XkBtdcnNkL17SGv1TRc15fRGVO4T30KXNFEzz2EwdJu4I4h7jQDpMnB7favFE2VflMUuRzjzR9_rNcFSlKfDBU9gJQVTvyIzFyzgU7kXS8l7jWLBKQy3feqSayBAOxy89P84kY84vIAVj_hW6-NM8RMuNaDfN1xo41mMirmQWpRvk7_KAMDMLkb1Im1-kbIgPmmIutF_J1jyKpWtZHfxh6sAFSAfgPRrGd4xU',
];

const galleryFallbackImages = [
	'https://lh3.googleusercontent.com/aida-public/AB6AXuAkLajToNwQsjzb5Ws6lSHGtQaeEPSJe3TJ8Y4zZd86ZafMWcFkMui-T00eAvoB7IdOUgNEkP8ZEc99iMEbFSi96PFqX0WOTVyg7yw40uZQ8xtKjAkQ87hOGsof83L5PxIQLXxrWspoRlzMTTVBNmIEgyqTG8auaIb6TliBWbgqwGxhqlreJnwGBMB1z2i8sgBrhq81c5FgZ59YIUaWAeAwTF1cIHL_4l42zj8wEEk_Ah38j9xE1xmSbRbkBIHfB8EqpyqrHQo2zBI',
	'https://lh3.googleusercontent.com/aida-public/AB6AXuB_D3GHaTyUHuhJRV8I3s6mNzqw7JtPkfhwOqDNegqsCJvVyD6YMytXO-Ko7XMAh2iHcELhEB6ioFCHsPLc6jZaaVcKOW397d6vYpmqK95J7e9YwdrCQSVWf7Pg5MZfTwOBHRjEbp35K318w1noEYz_OShXlu7EHP_mMDr9bnjTVfQHywxY2pL3RhzNa4H8-B91tSeW2gS5GpUsldhdDbbO2j4BdFqecbgiRjyXnXf7re8cD3XRXDxJ7du42UTj81LIq5e_39MdaZg',
	'https://lh3.googleusercontent.com/aida-public/AB6AXuDiJBBBhZNc889aT4SdvEIvfT0h0CjQ7oSQ83VGO5bMipoTOm6Ka95x9qOG6t8wd-QppeXEvRgO7sLxpKM_7Tyvi2XvoOxx_xhV2AQ-ptFlqMDrEvn7WSP76XaX1joY-HeCvy8rOjcY4zsoC6KQNMRFJzrzERXJIDSMQhBcJ3WpnyFiR0lYot9_5NRiValWo8rdTgJQrLe2Gxc4atZso1NC3XyLi4VbBl6Vk0dK_jf9F-Hpvi-vq-6xb7HImzeRwPT9zzXkp00b3s0',
	'https://lh3.googleusercontent.com/aida-public/AB6AXuBBFU0LutRgCu49Bt0YRlDEDjz5WhZV9XThWAfnhXmmri-Mm78sZF1vhXmlz9hedHCiVr-q9FsouiJYqlSgzXS3NLWw95MoeqBqE0Z0hB6bZFZPuop377WIOy1JZh-eun4yu2IzWetgouw4IrNLcqJ1wrHgU-LRgf8BHpCsndhNb9eEHLjp2-pITmNclybkhBYlnNvM10CDI_gseKCKTnsbY7LBUpESY22k14TDDTGgW3esiYwVg9C6pdD-staTy0V-I3ufKoUs9QM',
];

const galleryCardThemes = [
	{
		rotation: 'rotate-neg-1',
		pinClasses: 'pin pin-blue',
		borderClasses: 'border-blue-100',
		badgeClasses: 'bg-blue-50 text-blue-700',
		iconWrapClasses: 'bg-blue-500 text-white',
	},
	{
		rotation: 'rotate-pos-2 mt-8',
		pinClasses: 'pin pin-yellow',
		borderClasses: 'border-yellow-100',
		badgeClasses: 'bg-yellow-50 text-yellow-700',
		iconWrapClasses: 'bg-yellow-500 text-white',
	},
	{
		rotation: 'rotate-pos-1',
		pinClasses: 'pin',
		borderClasses: 'border-green-100',
		badgeClasses: 'bg-green-50 text-green-700',
		iconWrapClasses: 'bg-green-500 text-white',
	},
	{
		rotation: 'rotate-neg-2 mt-4',
		pinClasses: 'pin pin-blue',
		borderClasses: 'border-purple-100',
		badgeClasses: 'bg-purple-50 text-purple-700',
		iconWrapClasses: 'bg-purple-500 text-white',
	},
];

const categoryIconMap = {
	ekstrakurikuler: 'sports_soccer',
	seni: 'palette',
	pembelajaran: 'science',
	pengumuman: 'campaign',
};

const categoryLabelMap = {
	ekstrakurikuler: galleryPage.filterExtracurricularLabel,
	seni: galleryPage.filterArtsLabel,
	pembelajaran: galleryPage.filterLearningLabel,
	pengumuman: galleryPage.filterAnnouncementsLabel,
};
---

<Layout
	title="Keseruan & Aktivitas Siswa - SDN Klagen 1"
	bodyClass="bg-[#f5f7f8] dark:bg-background-dark font-display text-[#111418] overflow-x-hidden"
>
	<div class="relative flex min-h-screen w-full flex-col">
		<header class="sticky top-0 z-50 flex items-center justify-between border-b border-gray-100 bg-white/90 backdrop-blur-md px-6 py-3 shadow-sm lg:px-10">
			<div class="flex items-center gap-3">
				<div class="h-10 w-10 overflow-hidden rounded-full ring-2 ring-primary/15">
					<img src="/sdnklagen.png" alt="Logo SDN Klagen 1" class="h-full w-full object-cover" />
				</div>
				<h2 class="text-xl font-black tracking-tight text-[#111418]">SDN Klagen 1</h2>
			</div>
			<nav class="hidden gap-3 md:flex items-center">
				<a
					class:list={[
						"flex items-center justify-center rounded-full bg-[#ef4444] px-5 py-2 text-sm font-bold text-white shadow-md transition-transform hover:scale-105 hover:bg-red-600",
						{ "nav-active": pathname === "/" }
					]}
					href="/"
					aria-current={pathname === "/" ? "page" : undefined}
				>
					Beranda
				</a>
				<a
					class:list={[
						"flex items-center justify-center rounded-full bg-[#3b82f6] px-5 py-2 text-sm font-bold text-white shadow-md transition-transform hover:scale-105 hover:bg-blue-600",
						{ "nav-active": pathname === "/tentang-kami" }
					]}
					href="/tentang-kami"
					aria-current={pathname === "/tentang-kami" ? "page" : undefined}
				>
					Tentang Kami
				</a>
				<a
					class:list={[
						"flex items-center justify-center rounded-full bg-[#facc15] px-5 py-2 text-sm font-bold text-[#111418] shadow-md transition-transform hover:scale-105 hover:bg-yellow-400",
						{ "nav-active": pathname === "/galeri" }
					]}
					href="/galeri"
					aria-current={pathname === "/galeri" ? "page" : undefined}
				>
					Galeri
				</a>
				<a
					class:list={[
						"flex items-center justify-center rounded-full bg-[#ef4444] px-5 py-2 text-sm font-bold text-white shadow-md transition-transform hover:scale-105 hover:bg-red-600",
						{ "nav-active": pathname === "/kontak" }
					]}
					href="/kontak"
					aria-current={pathname === "/kontak" ? "page" : undefined}
				>
					Kontak
				</a>
			</nav>
			<div class="flex items-center gap-4">
				<button
					class="hidden md:flex h-10 items-center justify-center rounded-full bg-primary px-6 text-sm font-bold text-white shadow-md transition-transform hover:scale-105 hover:bg-blue-600"
					type="button"
				>
					Masuk
				</button>
				<button class="md:hidden flex items-center justify-center rounded-full bg-gray-100 p-2 text-[#111418]" type="button">
					<span class="material-symbols-outlined">menu</span>
				</button>
			</div>
		</header>
		<main class="flex-1">
			<section class="relative overflow-hidden bg-white px-4 py-12 md:py-20 lg:px-40">
				<div class="absolute -left-10 top-20 h-32 w-32 rounded-full bg-yellow-200 opacity-50 blur-3xl"></div>
				<div class="absolute right-0 bottom-0 h-64 w-64 rounded-full bg-primary/20 opacity-50 blur-3xl"></div>
				<div class="relative mx-auto max-w-6xl">
					<div class="mb-8 flex flex-col items-center gap-4 text-center md:items-start md:text-left">
						<div class="inline-flex w-fit items-center gap-2 rounded-full bg-yellow-100 px-4 py-1.5 text-yellow-700">
							<span class="material-symbols-outlined text-lg">event_available</span>
							<span class="text-xs font-bold uppercase tracking-wide">{galleryPage.featuredBadgeLabel}</span>
						</div>
						<h1 class="text-3xl font-black leading-tight tracking-tight text-[#111418] md:text-4xl lg:text-5xl">
							{galleryPage.featuredTitle}
						</h1>
						<p class="max-w-2xl text-base font-medium leading-relaxed text-gray-600 md:text-lg">
							{galleryPage.featuredDescription}
						</p>
					</div>
					<div class="relative">
						<div
							class="flex flex-nowrap overflow-x-auto scroll-smooth snap-x snap-mandatory pb-6 pt-4 gap-6 md:gap-8 [-ms-scrollbar-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
						>
							{galleryPage.featuredActivities.map((activity, index) => {
								const theme = featuredThemes[index % featuredThemes.length];
								const badgeIcon = badgeIcons[index % badgeIcons.length];
								const fallbackImage = featuredFallbackImages[index % featuredFallbackImages.length];
								const slideId = `kegiatan-${index + 1}`;
								const imageUrl = getImageUrl(activity.image) ?? fallbackImage;
								const tagStyles = [
									[
										'bg-blue-50 text-blue-700',
										'bg-green-50 text-green-700',
										'bg-yellow-50 text-yellow-700',
									],
									[
										'bg-pink-50 text-pink-700',
										'bg-purple-50 text-purple-700',
										'bg-orange-50 text-orange-700',
									],
									[
										'bg-blue-50 text-blue-700',
										'bg-emerald-50 text-emerald-700',
										'bg-indigo-50 text-indigo-700',
									],
								][index % 3];

								return (
									<article
										id={slideId}
										class:list={[
											'snap-center flex-none w-[92%] md:w-[78%] bg-white shadow-xl rounded-3xl border overflow-hidden',
											theme.cardBorder,
										]}
									>
										<div class="grid gap-6 p-6 md:grid-cols-[1.1fr,0.9fr] md:items-center md:p-10">
											<div class="flex flex-col gap-5">
												<div
													class:list={[
														'inline-flex w-fit items-center gap-2 rounded-full px-4 py-1.5',
														theme.badgeBg,
														theme.badgeText,
													]}
												>
													<span class="material-symbols-outlined text-lg">{badgeIcon}</span>
													<span class="text-xs font-bold uppercase tracking-wide">{activity.badgeLabel}</span>
												</div>
												<h2 class="text-3xl font-black text-[#111418] md:text-4xl">
													{activity.title}
													{activity.highlightedText ? (
														<>
															{' '}
															<span class={theme.highlightText}>{activity.highlightedText}</span>
														</>
													) : null}
												</h2>
												<p class="text-base font-medium leading-relaxed text-gray-600 md:text-lg">
													{activity.description}
												</p>
												<div class="flex flex-wrap gap-2">
													{activity.tags.map((tag, tagIndex) => (
														<span
															class:list={[
																'rounded-full px-3 py-1 text-xs font-bold',
																tagStyles[tagIndex % tagStyles.length],
															]}
														>
															{tag}
														</span>
													))}
												</div>
												<div class="flex flex-wrap gap-3">
													<button
														class="flex h-11 items-center justify-center gap-2 rounded-full bg-primary px-6 text-sm font-bold text-white shadow-lg transition-transform hover:scale-105"
														type="button"
													>
														<span class="material-symbols-outlined text-base">event_note</span>
														{activity.primaryButtonLabel}
													</button>
													<button
														class="flex h-11 items-center justify-center gap-2 rounded-full bg-white border-2 border-gray-200 px-6 text-sm font-bold text-gray-700 hover:bg-gray-50 transition-colors"
														type="button"
													>
														<span class="material-symbols-outlined text-base">calendar_month</span>
														{activity.secondaryButtonLabel}
													</button>
												</div>
											</div>
											<div class="relative flex justify-center">
												<div
													class:list={[
														'absolute -inset-4 rounded-full bg-gradient-to-br opacity-30 blur-lg',
														theme.glowGradient,
													]}
												></div>
												<div
													class:list={[
														'relative flex h-64 w-64 items-center justify-center rounded-full border-[8px] bg-white overflow-hidden ring-4 ring-offset-4',
														theme.ringBorder,
														theme.ringClasses,
													]}
												>
													<div
														class="h-full w-full bg-cover bg-center"
														data-alt={activity.imageAlt}
														style={`background-image: url("${imageUrl}");`}
													></div>
													<div
														class:list={[
															'absolute -bottom-2 right-6 flex h-16 w-16 items-center justify-center rounded-full bg-gradient-to-b text-white shadow-lg border-4 border-white',
															theme.bubbleGradient,
														]}
													>
														<span class="material-symbols-outlined text-4xl drop-shadow-sm">{theme.bubbleIcon}</span>
													</div>
												</div>
											</div>
										</div>
									</article>
								);
							})}
						</div>
						<div class="mt-4 flex items-center justify-center gap-3">
							{galleryPage.featuredActivities.map((activity, index) => {
								const slideId = `kegiatan-${index + 1}`;
								const theme = featuredThemes[index % featuredThemes.length];
								return (
									<a
										class:list={[
											'h-3 w-3 rounded-full shadow-sm ring-2 hover:scale-110 transition-transform',
											theme.dotClasses,
										]}
										href={`#${slideId}`}
										aria-label={`Lihat slide ${activity.badgeLabel.toLowerCase()}`}
									></a>
								);
							})}
						</div>
					</div>
				</div>
			</section>
			<section class="cork-texture relative w-full py-16 px-4 border-t-8 border-yellow-700/20 shadow-inner">
				<div class="mx-auto max-w-7xl">
					<div class="mb-12 flex flex-col items-center gap-8">
						<div class="rounded-xl bg-white/90 px-8 py-4 text-center shadow-lg backdrop-blur-sm -rotate-1 border border-gray-200">
							<h2 class="text-3xl font-black text-[#111418] md:text-4xl">{galleryPage.activitiesTitle}</h2>
							<p class="mt-2 text-gray-600 font-medium">
								{galleryPage.activitiesSubtitle}
							</p>
						</div>
						<div class="flex flex-wrap justify-center gap-4" data-gallery-filter-group>
							<button
								class="group flex items-center gap-2 rounded-full bg-white px-6 py-3 shadow-md hover:bg-gray-50 transition-all hover:-translate-y-1"
								type="button"
								data-gallery-filter="all"
								aria-pressed="true"
							>
								<span class="material-symbols-outlined text-gray-400 group-hover:text-gray-600">grid_view</span>
								<span class="font-bold text-gray-600">{galleryPage.filterAllLabel}</span>
							</button>
							<button
								class="group flex items-center gap-2 rounded-full bg-[#ff6b6b] px-6 py-3 text-white shadow-md hover:bg-[#fa5252] transition-all hover:-translate-y-1 hover:rotate-2"
								type="button"
								data-gallery-filter="ekstrakurikuler"
								aria-pressed="false"
							>
								<span class="material-symbols-outlined">sports_soccer</span>
								<span class="font-bold">{galleryPage.filterExtracurricularLabel}</span>
							</button>
							<button
								class="group flex items-center gap-2 rounded-full bg-[#fcc419] px-6 py-3 text-white shadow-md hover:bg-[#fab005] transition-all hover:-translate-y-1 hover:-rotate-2"
								type="button"
								data-gallery-filter="seni"
								aria-pressed="false"
							>
								<span class="material-symbols-outlined">palette</span>
								<span class="font-bold">{galleryPage.filterArtsLabel}</span>
							</button>
							<button
								class="group flex items-center gap-2 rounded-full bg-[#51cf66] px-6 py-3 text-white shadow-md hover:bg-[#40c057] transition-all hover:-translate-y-1 hover:rotate-1"
								type="button"
								data-gallery-filter="pembelajaran"
								aria-pressed="false"
							>
								<span class="material-symbols-outlined">science</span>
								<span class="font-bold">{galleryPage.filterLearningLabel}</span>
							</button>
							<button
								class="group flex items-center gap-2 rounded-full bg-[#4dabf7] px-6 py-3 text-white shadow-md hover:bg-[#339af0] transition-all hover:-translate-y-1 hover:-rotate-1"
								type="button"
								data-gallery-filter="pengumuman"
								aria-pressed="false"
							>
								<span class="material-symbols-outlined">campaign</span>
								<span class="font-bold">{galleryPage.filterAnnouncementsLabel}</span>
							</button>
						</div>
					</div>
					<div class="columns-1 gap-6 sm:columns-2 lg:columns-3 xl:columns-4 space-y-6">
						{galleryPage.galleryItems.map((item, index) => {
							const theme = galleryCardThemes[index % galleryCardThemes.length];
							const imageUrl = getImageUrl(item.image) ?? galleryFallbackImages[index % galleryFallbackImages.length];
							const iconName = item.icon?.trim() || categoryIconMap[item.category];
							const categoryLabel = categoryLabelMap[item.category];
							return (
								<article
									class:list={[
										'break-inside-avoid relative hover-lift transition-transform duration-300',
										theme.rotation,
									]}
									data-gallery-card
									data-gallery-category={item.category}
								>
									<div
										class:list={[
											'absolute -top-3 left-1/2 z-20 h-5 w-5 -translate-x-1/2 rounded-full',
											theme.pinClasses,
										]}
									></div>
									<div
										class:list={[
											'relative overflow-hidden rounded-2xl border bg-white p-3 pb-5 shadow-polaroid',
											theme.borderClasses,
										]}
									>
										<div class="relative aspect-[4/3] w-full overflow-hidden rounded-xl bg-gray-100">
											<div
												class="h-full w-full bg-cover bg-center transition-transform duration-700 hover:scale-110"
												data-alt={item.imageAlt}
												style={`background-image: url("${imageUrl}");`}
											></div>
											<div class="absolute right-3 top-3">
												<div
													class:list={[
														'flex h-9 w-9 items-center justify-center rounded-full shadow-lg',
														theme.iconWrapClasses,
													]}
												>
													<span class="material-symbols-outlined text-base">{iconName}</span>
												</div>
											</div>
										</div>
										<div class="mt-4 flex flex-col gap-2">
											<div class="flex items-start justify-between gap-2">
												<h3 class="text-lg font-black leading-tight text-gray-800">{item.title}</h3>
												<span
													class:list={[
														'rounded-full px-2.5 py-1 text-[11px] font-bold uppercase tracking-wide',
														theme.badgeClasses,
													]}
												>
													{categoryLabel}
												</span>
											</div>
											<p class="text-sm font-medium leading-relaxed text-gray-600">{item.description}</p>
											{item.metaLabel ? (
												<p class="text-xs font-semibold text-gray-400">{item.metaLabel}</p>
											) : null}
